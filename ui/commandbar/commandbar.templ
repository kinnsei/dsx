package commandbar

import (
	"fmt"

	"github.com/kinnsei/dsx/ds"
	"github.com/kinnsei/dsx/ui/icon"
	"github.com/kinnsei/dsx/utils"
)

// CommandBarSignals holds the reactive state for the command bar.
type CommandBarSignals struct {
	Mode      string `json:"mode"`      // "" | "text" | "file" | "voice"
	Text      string `json:"text"`      // text input value
	Recording bool   `json:"recording"` // voice recording active
}

// Props configures the command bar.
type Props struct {
	ID          string
	Class       string
	Attributes  templ.Attributes
	Placeholder string   // placeholder text when collapsed (default "Type something...")
	SubmitURL   string   // POST endpoint for text submit
	UploadURL   string   // POST endpoint for file upload (enables file tab)
	VoiceURL    string   // POST endpoint for voice (enables voice tab)
	Suggestions []string // quick-fill suggestion chips in text mode
	FileHint    string   // subtitle in file drop zone (default "Drop a file or click to browse")
	Embedded    bool     // when true: no collapsed state, no close behavior, no outer chrome
}

// CommandBar renders an expandable multi-mode command input.
// Supports text input, file upload, and voice recording modes.
// Collapsed: placeholder bar with shortcut buttons.
// Expanded: tabbed interface with mode-specific content.
templ CommandBar(props Props) {
	{{
		id := props.ID
		if id == "" {
			id = utils.RandomID()
		}
		placeholder := props.Placeholder
		if placeholder == "" {
			placeholder = "Type something..."
		}
		fileHint := props.FileHint
		if fileHint == "" {
			fileHint = "Drop a file or click to browse"
		}

		initialMode := ""
		if props.Embedded {
			initialMode = "text"
		}
		signals := ds.NewSignals(id, CommandBarSignals{Mode: initialMode, Text: "", Recording: false})
		modeSignal := signals.Signal("mode")
		textSignal := signals.Signal("text")
		recordingSignal := signals.Signal("recording")

		isClosed := fmt.Sprintf("%s === ''", modeSignal)
		isOpen := fmt.Sprintf("%s !== ''", modeSignal)
		isText := fmt.Sprintf("%s === 'text'", modeSignal)
		isFile := fmt.Sprintf("%s === 'file'", modeSignal)
		isVoice := fmt.Sprintf("%s === 'voice'", modeSignal)

		openText := fmt.Sprintf("%s; requestAnimationFrame(()=>document.querySelector('#%s textarea')?.focus())", signals.SetString("mode", "text"), id)
		openFile := signals.SetString("mode", "file")
		openVoice := signals.SetString("mode", "voice")

		// In embedded mode: just clear text, stay in current mode.
		// In standalone mode: close entirely (reset mode + text + recording).
		// Uses semicolons — Datastar supports them at the top level and inside {} blocks.
		var clearExpr string
		if props.Embedded {
			clearExpr = fmt.Sprintf("%s; %s",
				signals.SetString("text", ""),
				signals.Set("recording", "false"),
			)
		} else {
			clearExpr = fmt.Sprintf("%s; %s; %s",
				signals.SetString("mode", ""),
				signals.SetString("text", ""),
				signals.Set("recording", "false"),
			)
		}

		hasFile := props.UploadURL != ""
		hasVoice := props.VoiceURL != ""
	}}
	<div
		id={ id }
		role="search"
		data-signals={ signals.DataSignals }
		class={ utils.TwMerge(props.Class) }
		{ props.Attributes... }
	>
		if !props.Embedded {
			<!-- Collapsed state -->
			<div
				style="display: none;"
				{ ds.Show(isClosed)... }
				class="flex items-center gap-2 bg-base-200 border border-base-300 rounded-box px-3 py-2.5 cursor-text hover:border-base-content/30 transition-colors"
				{ ds.OnClick(openText)... }
			>
				<span class="text-sm text-base-content/40 flex-1">{ placeholder }</span>
				<div class="flex gap-0.5">
					if hasFile {
						<button
							class="btn btn-ghost btn-xs btn-square"
							aria-label="Attach file"
							{ ds.OnClick(fmt.Sprintf("evt.stopPropagation(); %s", openFile))... }
						>
							@icon.Paperclip(icon.Props{Size: 14, Class: "text-base-content/40"})
						</button>
					}
					if hasVoice {
						<button
							class="btn btn-ghost btn-xs btn-square"
							aria-label="Voice input"
							{ ds.OnClick(fmt.Sprintf("evt.stopPropagation(); %s", openVoice))... }
						>
							@icon.Mic(icon.Props{Size: 14, Class: "text-base-content/40"})
						</button>
					}
				</div>
				<kbd class="kbd kbd-xs text-base-content/30">⌘K</kbd>
			</div>
		}
		<!-- Expanded state -->
		<div
			if !props.Embedded {
				style="display: none;"
			}
			if !props.Embedded {
				{ ds.Show(isOpen)... }
			}
			if props.Embedded {
				class="overflow-hidden"
			} else {
				class="bg-base-100 rounded-box border border-base-300 shadow-lg overflow-hidden"
			}
		>
			<!-- Mode tabs + close -->
			<div class="flex items-center justify-between px-3 pt-2.5">
				<div class="flex gap-1">
					<button
						class="btn btn-xs"
						data-class={ fmt.Sprintf("{'btn-neutral': %s, 'btn-ghost': !(%s)}", isText, isText) }
						{ ds.OnClick(openText)... }
					>
						@icon.Pencil(icon.Props{Size: 12})
						Type
					</button>
					if hasFile {
						<button
							class="btn btn-xs"
							data-class={ fmt.Sprintf("{'btn-neutral': %s, 'btn-ghost': !(%s)}", isFile, isFile) }
							{ ds.OnClick(openFile)... }
						>
							@icon.Paperclip(icon.Props{Size: 12})
							File
						</button>
					}
					if hasVoice {
						<button
							class="btn btn-xs"
							data-class={ fmt.Sprintf("{'btn-neutral': %s, 'btn-ghost': !(%s)}", isVoice, isVoice) }
							{ ds.OnClick(openVoice)... }
						>
							@icon.Mic(icon.Props{Size: 12})
							Voice
						</button>
					}
				</div>
				if !props.Embedded {
					<button
						class="btn btn-ghost btn-xs btn-square"
						aria-label="Close"
						{ ds.OnClick(clearExpr)... }
					>
						@icon.X(icon.Props{Size: 14})
					</button>
				}
			</div>
			<!-- Text mode -->
			<div
				style="display: none;"
				{ ds.Show(isText)... }
			>
				<div class="p-3">
					<textarea
						class="textarea textarea-ghost w-full min-h-16 text-sm p-0 focus:outline-none"
						placeholder={ placeholder }
						rows="2"
						{ ds.Bind(id, "text")... }
						data-on:keydown={ fmt.Sprintf("if(evt.key==='Enter'&&!evt.shiftKey&&%s.trim()){evt.preventDefault(); %s; %s} if(evt.key==='Escape'){%s}",
							textSignal,
							actionExpr(props.SubmitURL, id),
							clearExpr,
							clearExpr,
						) }
					></textarea>
				</div>
				if len(props.Suggestions) > 0 {
					<div class="flex gap-1.5 px-3 pb-2 flex-wrap">
						for _, s := range props.Suggestions {
							<button
								class="btn btn-xs btn-ghost text-base-content/50 hover:text-base-content"
								{ ds.OnClick(signals.SetString("text", s))... }
							>
								{ s }
							</button>
						}
					</div>
				}
				<div class="flex items-center justify-end gap-2 px-3 py-2 border-t border-base-200">
					if props.SubmitURL != "" {
						<button
							class="btn btn-sm btn-neutral"
							{ ds.OnClick(fmt.Sprintf("if(%s.trim()){%s; %s}",
								textSignal,
								actionExpr(props.SubmitURL, id),
								clearExpr,
							))... }
						>
							Send
						</button>
					}
				</div>
			</div>
			<!-- File mode -->
			if hasFile {
				<div
					style="display: none;"
					{ ds.Show(isFile)... }
				>
					<form enctype="multipart/form-data">
						<div class="p-3">
							<label class="flex flex-col items-center justify-center gap-2 border-2 border-dashed border-base-300 rounded-box p-8 cursor-pointer hover:border-base-content/30 hover:bg-base-200/30 transition-colors">
								@icon.FileUp(icon.Props{Size: 32, Class: "text-base-content/30"})
								<div class="text-sm font-semibold text-base-content/70">{ fileHint }</div>
								<div class="text-xs text-base-content/40">PDF, photo, receipt, document</div>
								<input
									type="file"
									name="files"
									class="hidden"
									multiple
									data-on:change={ fmt.Sprintf("%s; %s",
									actionExpr(props.UploadURL, id),
									clearExpr,
								) }
								/>
							</label>
						</div>
						<div class="flex items-center justify-center gap-2 px-3 pb-3">
							<label class="btn btn-sm btn-ghost">
								@icon.Camera(icon.Props{Size: 14})
								Camera
								<input type="file" name="files" accept="image/*" capture="environment" class="hidden"/>
							</label>
							<label class="btn btn-sm btn-ghost">
								@icon.FolderOpen(icon.Props{Size: 14})
								Browse
								<input
									type="file"
									name="files"
									class="hidden"
									multiple
									data-on:change={ fmt.Sprintf("%s; %s",
									actionExpr(props.UploadURL, id),
									clearExpr,
								) }
								/>
							</label>
						</div>
					</form>
				</div>
			}
			<!-- Voice mode -->
			if hasVoice {
				<div
					style="display: none;"
					{ ds.Show(isVoice)... }
				>
					<!-- Idle state -->
					<div
						class="p-6 text-center"
						style="display: none;"
						{ ds.Show(fmt.Sprintf("!%s", recordingSignal))... }
					>
						<div class="text-sm text-base-content/50 mb-4">Tap to start recording</div>
						<button
							class="btn btn-circle btn-lg bg-secondary text-secondary-content hover:bg-secondary/80 mx-auto"
							{ ds.OnClick(signals.Set("recording", "true"))... }
						>
							@icon.Mic(icon.Props{Size: 24})
						</button>
					</div>
					<!-- Recording state -->
					<div
						class="p-6 text-center"
						style="display: none;"
						{ ds.Show(recordingSignal)... }
					>
						<div class="flex items-center justify-center gap-2 text-sm font-semibold text-secondary mb-4">
							<span class="w-2 h-2 rounded-full bg-error animate-pulse"></span>
							Recording...
						</div>
						<!-- Waveform visualization -->
						<div class="flex items-center justify-center gap-0.5 h-8 mb-4">
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-2" style="animation-delay: 0ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-5" style="animation-delay: 50ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-3" style="animation-delay: 100ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-7" style="animation-delay: 150ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-4" style="animation-delay: 200ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-6" style="animation-delay: 250ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-2" style="animation-delay: 300ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-5" style="animation-delay: 350ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-3" style="animation-delay: 400ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-7" style="animation-delay: 450ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-4" style="animation-delay: 500ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-6" style="animation-delay: 550ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-2" style="animation-delay: 600ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-5" style="animation-delay: 650ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-3" style="animation-delay: 700ms;"></div>
							<div class="w-1 bg-secondary/60 rounded-full animate-pulse h-7" style="animation-delay: 750ms;"></div>
						</div>
						<button
							class="btn btn-circle btn-lg bg-error text-error-content hover:bg-error/80 mx-auto"
							{ ds.OnClick(fmt.Sprintf("%s; %s; %s",
								signals.Set("recording", "false"),
								actionExpr(props.VoiceURL, id),
								clearExpr,
							))... }
						>
							@icon.Square(icon.Props{Size: 18})
						</button>
					</div>
				</div>
			}
		</div>
	</div>
}

func actionExpr(url, componentID string) string {
	if url == "" {
		return "void 0"
	}
	return ds.Post(url, ds.WithRetries(0), ds.WithContentType("form"), ds.WithFilterSignals(componentID))
}
