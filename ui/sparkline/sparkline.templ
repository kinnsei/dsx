package sparkline

// Sparkline renders a small inline SVG trend chart.
templ Sparkline(props Props) {
	{{ d := computeData(props) }}
	if d.Points != "" {
		<svg
			width={ d.Width }
			height={ d.Height }
			if d.Class != "" {
				class={ d.Class }
			}
			style="flex-shrink: 0;"
		>
			<polyline
				points={ d.Points }
				fill="none"
				stroke={ d.Color }
				stroke-width={ d.StrokeWidth }
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
			if d.ShowDot {
				<circle
					cx={ d.LastDotCX }
					cy={ d.LastDotCY }
					r={ d.DotRadius }
					fill={ d.Color }
				/>
			}
		</svg>
	}
}
