package pages

import (
	"github.com/kinnsei/dsx/cmd/showcase/internal/components"
	"github.com/kinnsei/dsx/cmd/showcase/internal/layouts"
	"github.com/kinnsei/dsx/ui/separator"
)

templ Separators() {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "Separator — WebX Showcase",
		Description: "DaisyUI divider/separator component",
		CurrentPath: "/components/separator",
	}) {
		<div class="space-y-8">
			<div>
				<h1 class="text-3xl font-bold">Separator</h1>
				<p class="text-base-content/70 mt-2">
					Separators divide content vertically or horizontally, with an optional text label.
				</p>
			</div>
			@components.Example(components.ExampleProps{
				Title:     "Basic",
				TemplCode: `@separator.Separator()`,
			}) {
				<div class="flex w-full flex-col">
					<div class="card bg-base-300 rounded-box grid h-16 place-items-center">Content above</div>
					@separator.Separator()
					<div class="card bg-base-300 rounded-box grid h-16 place-items-center">Content below</div>
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "With Text",
				TemplCode: `@separator.Separator() {
    OR
}`,
			}) {
				<div class="flex w-full flex-col">
					<div class="card bg-base-300 rounded-box grid h-16 place-items-center">Content above</div>
					@separator.Separator() {
						OR
					}
					<div class="card bg-base-300 rounded-box grid h-16 place-items-center">Content below</div>
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Horizontal",
				TemplCode: `@separator.Separator(separator.Props{Direction: separator.DirectionHorizontal}) {
    OR
}`,
			}) {
				<div class="flex w-full">
					<div class="card bg-base-300 rounded-box grid h-20 grow place-items-center">Left</div>
					@separator.Separator(separator.Props{Direction: separator.DirectionHorizontal}) {
						OR
					}
					<div class="card bg-base-300 rounded-box grid h-20 grow place-items-center">Right</div>
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Color Variants",
				TemplCode: `@separator.Separator(separator.Props{Variant: separator.VariantPrimary}) {
    primary
}
@separator.Separator(separator.Props{Variant: separator.VariantSecondary}) {
    secondary
}
@separator.Separator(separator.Props{Variant: separator.VariantSuccess}) {
    success
}`,
			}) {
				<div class="flex w-full flex-col">
					@separator.Separator(separator.Props{Variant: separator.VariantNeutral}) {
						neutral
					}
					@separator.Separator(separator.Props{Variant: separator.VariantPrimary}) {
						primary
					}
					@separator.Separator(separator.Props{Variant: separator.VariantSecondary}) {
						secondary
					}
					@separator.Separator(separator.Props{Variant: separator.VariantAccent}) {
						accent
					}
					@separator.Separator(separator.Props{Variant: separator.VariantInfo}) {
						info
					}
					@separator.Separator(separator.Props{Variant: separator.VariantSuccess}) {
						success
					}
					@separator.Separator(separator.Props{Variant: separator.VariantWarning}) {
						warning
					}
					@separator.Separator(separator.Props{Variant: separator.VariantError}) {
						error
					}
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Text Position",
				TemplCode: `@separator.Separator(separator.Props{Position: separator.PositionStart}) {
    Start
}
@separator.Separator() {
    Center (default)
}
@separator.Separator(separator.Props{Position: separator.PositionEnd}) {
    End
}`,
			}) {
				<div class="flex w-full flex-col">
					@separator.Separator(separator.Props{Position: separator.PositionStart}) {
						Start
					}
					@separator.Separator() {
						Center (default)
					}
					@separator.Separator(separator.Props{Position: separator.PositionEnd}) {
						End
					}
				</div>
			}
		</div>
	}
}
