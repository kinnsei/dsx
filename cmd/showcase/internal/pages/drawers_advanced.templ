package pages

import (
	"fmt"

	"github.com/plaenen/webx"
	"github.com/plaenen/webx/cmd/showcase/internal/components"
	"github.com/plaenen/webx/cmd/showcase/internal/layouts"
	"github.com/plaenen/webx/ds"
	"github.com/plaenen/webx/ui/badge"
	"github.com/plaenen/webx/ui/card"
)

templ DrawersAdvanced() {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "Advanced Drawer — WebX Showcase",
		Description: "SSE-driven drawer with server-rendered content",
		CurrentPath: "/components/drawer-advanced",
	}) {
		{{
			wctx := webx.FromContext(ctx)
		}}
		<div class="space-y-8">
			<div>
				<h1 class="text-3xl font-bold">Advanced Drawer</h1>
				<p class="text-base-content/70 mt-2">
					Click a project card to open a detail drawer. The content is rendered server-side
					and delivered via SSE — no client-side JavaScript required.
				</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				@projectCard(wctx, "1", "WebX Framework", "Component library for Go + Templ + Datastar", "active", 78)
				@projectCard(wctx, "2", "Neon Database", "Serverless Postgres with branching", "active", 92)
				@projectCard(wctx, "3", "Data Pipeline", "ETL pipeline for analytics data", "paused", 45)
				@projectCard(wctx, "4", "Mobile App", "React Native client for the platform", "active", 63)
				@projectCard(wctx, "5", "Auth Service", "OAuth2 and OIDC identity provider", "completed", 100)
				@projectCard(wctx, "6", "Monitoring", "Observability stack with metrics and alerts", "planning", 12)
			</div>
			@components.Example(components.ExampleProps{
				Title: "How It Works",
				TemplCode: `templ projectCard(wctx *webx.WebXContext, id, name string) {
    @card.Card(card.Props{Class: "cursor-pointer hover:shadow-lg"}) {
        @card.Body(card.Props{
            Attributes: ds.Merge(
                ds.OnClick(ds.GetOnce(wctx.APIPath("/api/drawer/project/"+id))),
            ),
        }) {
            { name }
        }
    }
}`,
				HandlerCode: `func (h *drawerHandlers) showProject() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        id := chi.URLParam(r, "id")
        project := mockProjects[id]

        sse := datastar.NewSSE(w, r)
        ds.Send.Drawer(sse, pages.DrawerDetail(project))
    }
}`,
			}) {
				<ol class="list-decimal list-inside space-y-3 text-sm">
					<li>
						<span class="font-medium">Click a card</span> —
						triggers
						<code class="bg-base-200 px-1.5 py-0.5 rounded text-xs">{ "@get('/api/drawer/project/{id}')" }</code>
					</li>
					<li>
						<span class="font-medium">Handler renders</span> —
						calls
						<code class="bg-base-200 px-1.5 py-0.5 rounded text-xs">{ "ds.Send.Drawer(sse, pages.DrawerDetail(project))" }</code>
					</li>
					<li>
						<span class="font-medium">SSE patches DOM</span> —
						the drawer shell + content replaces
						<code class="bg-base-200 px-1.5 py-0.5 rounded text-xs">{ "#drawer-panel" }</code>
						via PatchElements
					</li>
					<li>
						<span class="font-medium">Close</span> —
						inline expression clears the container, no SSE roundtrip
					</li>
				</ol>
			}
		</div>
	}
}

templ projectCard(wctx *webx.WebXContext, id, name, description, status string, progress int) {
	@card.Card(card.Props{Class: "cursor-pointer hover:shadow-lg transition-shadow"}) {
		@card.Body(card.Props{
			Attributes: ds.Merge(
				ds.OnClick(ds.GetOnce(wctx.APIPath("/api/drawer/project/"+id))),
			),
		}) {
			<div class="flex items-start justify-between">
				@card.Title() {
					{ name }
				}
				@statusBadge(status)
			</div>
			<p class="text-sm text-base-content/70 mt-1">{ description }</p>
			<div class="mt-4">
				<div class="flex justify-between text-xs mb-1">
					<span>Progress</span>
					<span>{ fmt.Sprintf("%d%%", progress) }</span>
				</div>
				<progress class="progress progress-primary w-full" value={ fmt.Sprintf("%d", progress) } max="100"></progress>
			</div>
		}
	}
}

templ statusBadge(status string) {
	switch status {
		case "active":
			@badge.Badge(badge.Props{Variant: badge.VariantSuccess, Size: badge.SizeSm}) {
				Active
			}
		case "completed":
			@badge.Badge(badge.Props{Variant: badge.VariantInfo, Size: badge.SizeSm}) {
				Completed
			}
		case "paused":
			@badge.Badge(badge.Props{Variant: badge.VariantWarning, Size: badge.SizeSm}) {
				Paused
			}
		case "planning":
			@badge.Badge(badge.Props{Variant: badge.VariantNeutral, Size: badge.SizeSm}) {
				Planning
			}
	}
}
