package pages

import (
	"github.com/plaenen/webx/cmd/showcase/internal/components"
	"github.com/plaenen/webx/ds"
	"github.com/plaenen/webx/cmd/showcase/internal/layouts"
	"github.com/plaenen/webx/ui/button"
	"github.com/plaenen/webx/ui/drawer"
	"github.com/plaenen/webx/ui/menu"
)

templ Drawers() {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "Drawer - WebX Showcase",
		Description: "DaisyUI drawer with Datastar signals",
		CurrentPath: "/components/drawer",
	}) {
		<div class="space-y-8">
			<div>
				<h1 class="text-3xl font-bold">Drawer</h1>
				<p class="text-base-content/70 mt-2">
					DaisyUI drawer component controlled by Datastar signals.
				</p>
			</div>
			@components.Example(components.ExampleProps{
				Title: "How it works",
				TemplCode: `signals := ds.NewSignals("my_drawer", drawer.DrawerSignals{Open: false})

<div data-signals={ signals.DataSignals }>
    @button.Button(button.Props{
        OnClick: signals.Toggle("open"),
    }) {
        Toggle Drawer
    }
</div>`,
			}) {
				<div class="space-y-3 text-sm">
					<p>The drawer combines DaisyUI CSS classes for styling with Datastar signals for state management.</p>
					<ul class="list-disc list-inside space-y-1">
						<li>SignalManager namespaces signals per drawer instance</li>
						<li>data-class toggles drawer-open based on signal state</li>
						<li>lg:drawer-open keeps sidebar visible on desktop</li>
						<li>Overlay click sets the signal to false to close</li>
					</ul>
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Standalone Drawer Demo",
				TemplCode: `signals := ds.NewSignals("demo_drawer", drawer.DrawerSignals{Open: false})

<div data-signals={ signals.DataSignals }>
    @button.Button(button.Props{
        Variant: button.VariantPrimary,
        Size:    button.SizeSm,
        OnClick: signals.Toggle("open"),
    }) {
        Toggle Drawer
    }
    // Drawer panel with slide-in transition
    <div data-class={ ds.NewDataClass().
        Add("-translate-x-full", "!"+signals.Signal("open")).
        Add("translate-x-0", signals.Signal("open")).Build() }>
        @menu.Menu(menu.Props{Class: "p-0"}) {
            @menu.Title() { Demo Menu }
            @menu.Item(menu.ItemProps{Href: "#"}) { Dashboard }
        }
    </div>
</div>`,
			}) {
				<p class="mb-4">This is a self-contained drawer inside the page content.</p>
				@inlineDrawerDemo()
			}
			@components.Example(components.ExampleProps{
				Title: "Right Side (drawer-end)",
				TemplCode: `signals := ds.NewSignals("demo_drawer_end", drawer.DrawerSignals{Open: false})

<div data-signals={ signals.DataSignals }>
    @button.Button(button.Props{
        Variant: button.VariantPrimary,
        Size:    button.SizeSm,
        OnClick: signals.Toggle("open"),
    }) {
        Toggle Right Drawer
    }
    // Right-side panel with slide-in from right
    <div data-class={ ds.NewDataClass().
        Add("translate-x-full", "!"+signals.Signal("open")).
        Add("translate-x-0", signals.Signal("open")).Build() }>
        @menu.Menu(menu.Props{Class: "p-0"}) {
            @menu.Title() { Right Panel }
            @menu.Item(menu.ItemProps{Href: "#"}) { Notifications }
        }
    </div>
</div>`,
			}) {
				<p class="mb-4">Drawer positioned on the right side of the content.</p>
				@inlineDrawerEndDemo()
			}
		</div>
	}
}

templ inlineDrawerEndDemo() {
	{{
		signals := ds.NewSignals("demo_drawer_end", drawer.DrawerSignals{Open: false})
	}}
	<div
		data-signals={ signals.DataSignals }
		class="border border-base-300 rounded-lg overflow-hidden h-64 relative"
	>
		<div class="p-4">
			@button.Button(button.Props{
				Variant: button.VariantPrimary,
				Size:    button.SizeSm,
				OnClick: signals.Toggle("open"),
			}) {
				Toggle Right Drawer
			}
			<span class="ml-3 text-sm text-base-content/60">
				State:
				<code class="badge badge-sm" data-text={ signals.Conditional("open", "'open'", "'closed'") }>closed</code>
			</span>
		</div>
		<div
			class="absolute inset-y-0 right-0 w-52 bg-base-200 border-l border-base-300 p-4 transition-transform duration-200 z-10"
			data-class={ ds.NewDataClass().Add("translate-x-full", "!"+signals.Signal("open")).Add("translate-x-0", signals.Signal("open")).Build() }
		>
			@menu.Menu(menu.Props{Class: "p-0"}) {
				@menu.Title() {
					Right Panel
				}
				@menu.Item(menu.ItemProps{Href: "#"}) {
					Notifications
				}
				@menu.Item(menu.ItemProps{Href: "#"}) {
					Messages
				}
			}
		</div>
		<div
			class="absolute inset-0 bg-black/30 transition-opacity duration-200"
			data-show={ signals.Signal("open") }
			{ ds.OnClick(signals.Set("open", "false"))... }
			style="display: none;"
		></div>
	</div>
}

templ inlineDrawerDemo() {
	{{
		signals := ds.NewSignals("demo_drawer", drawer.DrawerSignals{Open: false})
	}}
	<div
		data-signals={ signals.DataSignals }
		class="border border-base-300 rounded-lg overflow-hidden h-64 relative"
	>
		<div class="p-4">
			@button.Button(button.Props{
				Variant: button.VariantPrimary,
				Size:    button.SizeSm,
				OnClick: signals.Toggle("open"),
			}) {
				Toggle Drawer
			}
			<span class="ml-3 text-sm text-base-content/60">
				State:
				<code class="badge badge-sm" data-text={ signals.Conditional("open", "'open'", "'closed'") }>closed</code>
			</span>
		</div>
		<div
			class="absolute inset-y-0 left-0 w-52 bg-base-200 border-r border-base-300 p-4 transition-transform duration-200 z-10"
			data-class={ ds.NewDataClass().Add("-translate-x-full", "!"+signals.Signal("open")).Add("translate-x-0", signals.Signal("open")).Build() }
		>
			@menu.Menu(menu.Props{Class: "p-0"}) {
				@menu.Title() {
					Demo Menu
				}
				@menu.Item(menu.ItemProps{Href: "#"}) {
					Dashboard
				}
				@menu.Item(menu.ItemProps{Href: "#"}) {
					Settings
				}
				@menu.Item(menu.ItemProps{Href: "#"}) {
					Profile
				}
			}
		</div>
		<div
			class="absolute inset-0 bg-black/30 transition-opacity duration-200"
			data-show={ signals.Signal("open") }
			{ ds.OnClick(signals.Set("open", "false"))... }
			style="display: none;"
		></div>
	</div>
}
