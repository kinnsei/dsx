package pages

import (
	"github.com/plaenen/webx/cmd/showcase/internal/components"
	"github.com/plaenen/webx/cmd/showcase/internal/layouts"
	"github.com/plaenen/webx/ui/codeview"
)

templ CodeViews() {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "Code View — WebX Showcase",
		Description: "Syntax-highlighted code display with copy button",
		CurrentPath: "/components/code-view",
	}) {
		<div class="space-y-8">
			<div>
				<h1 class="text-3xl font-bold">Code View</h1>
				<p class="text-base-content/70 mt-2">
					Syntax-highlighted code blocks with copy-to-clipboard. Uses Chroma { "for" } server-side highlighting with DaisyUI color classes.
				</p>
			</div>
			@components.Example(components.ExampleProps{
				Title: "Go",
				TemplCode: `@codeview.CodeView(codeview.Props{
    Code: goCode,
    Language: "go",
})`,
			}) {
				@codeview.CodeView(codeview.Props{
					Code:     goExample,
					Language: "go",
				})
			}
			@components.Example(components.ExampleProps{
				Title: "Templ",
				TemplCode: `@codeview.CodeView(codeview.Props{
    Code: templCode,
    Language: "templ",
})`,
			}) {
				@codeview.CodeView(codeview.Props{
					Code:     templExample,
					Language: "templ",
				})
			}
			@components.Example(components.ExampleProps{
				Title: "HTML",
				TemplCode: `@codeview.CodeView(codeview.Props{
    Code: htmlCode,
    Language: "html",
})`,
			}) {
				@codeview.CodeView(codeview.Props{
					Code:     htmlExample,
					Language: "html",
				})
			}
			@components.Example(components.ExampleProps{
				Title: "SQL",
				TemplCode: `@codeview.CodeView(codeview.Props{
    Code: sqlCode,
    Language: "sql",
})`,
			}) {
				@codeview.CodeView(codeview.Props{
					Code:     sqlExample,
					Language: "sql",
				})
			}
			@components.Example(components.ExampleProps{
				Title: "Shell",
				TemplCode: `@codeview.CodeView(codeview.Props{
    Code: shellCode,
    Language: "sh",
})`,
			}) {
				@codeview.CodeView(codeview.Props{
					Code:     shellExample,
					Language: "sh",
				})
			}
		</div>
	}
}

var goExample = `package main

import (
	"fmt"
	"net/http"

	"github.com/go-chi/chi/v5"
	"github.com/plaenen/webx/ds"
	"github.com/starfederation/datastar-go/datastar"
)

func main() {
	r := chi.NewRouter()

	r.Get("/greet", func(w http.ResponseWriter, r *http.Request) {
		sse := datastar.NewSSE(w, r)
		ds.Send.Toast(sse, ds.ToastSuccess, "Hello, World!")
	})

	fmt.Println("Server started on :3000")
	http.ListenAndServe(":3000", r)
}`

var templExample = `templ UserCard(name string, role string, active bool) {
	@card.Card() {
		@card.Body() {
			@card.Title() {
				{ name }
			}
			<p class="text-sm text-base-content/70">{ role }</p>
			if active {
				@badge.Badge(badge.Props{Variant: badge.VariantSuccess}) {
					Active
				}
			}
			<div class="card-actions mt-4">
				<button
					class="btn btn-primary btn-sm"
					{ ds.OnClick(ds.GetOnce(wctx.APIPath("/user/details")))... }
				>
					View Details
				</button>
			</div>
		}
	}
}`

