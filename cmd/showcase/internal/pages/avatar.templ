package pages

import (
	"github.com/laenen-partners/dsx/cmd/showcase/internal/components"
	"github.com/laenen-partners/dsx/cmd/showcase/internal/layouts"
	"github.com/laenen-partners/dsx/ui/avatar"
)

const sampleAvatarImg = "https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"

templ Avatars() {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "Avatar — WebX Showcase",
		Description: "DaisyUI avatar component",
		CurrentPath: "/components/avatar",
	}) {
		<div class="space-y-8">
			<div>
				<h1 class="text-3xl font-bold">Avatar</h1>
				<p class="text-base-content/70 mt-2">
					Avatars display user profile images, initials, or placeholder content.
				</p>
			</div>
			@components.Example(components.ExampleProps{
				Title: "Basic",
				TemplCode: `@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "User"})`,
			}) {
				<div class="flex flex-wrap items-center gap-4">
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "User"})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Sizes",
				TemplCode: `@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "XS", Size: avatar.SizeXs})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "SM", Size: avatar.SizeSm})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "MD", Size: avatar.SizeMd})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "LG", Size: avatar.SizeLg})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "XL", Size: avatar.SizeXl})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "2XL", Size: avatar.Size2xl})`,
			}) {
				<div class="flex flex-wrap items-end gap-4">
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "XS", Size: avatar.SizeXs})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "SM", Size: avatar.SizeSm})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "MD", Size: avatar.SizeMd})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "LG", Size: avatar.SizeLg})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "XL", Size: avatar.SizeXl})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "2XL", Size: avatar.Size2xl})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Shapes",
				TemplCode: `@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "Circle", Shape: avatar.ShapeCircle})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "Rounded", Shape: avatar.ShapeRounded})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "Squircle", Shape: avatar.ShapeSquircle})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "Heart", Shape: avatar.ShapeHeart})`,
			}) {
				<div class="flex flex-wrap items-center gap-4">
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Circle", Shape: avatar.ShapeCircle})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Rounded", Shape: avatar.ShapeRounded})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Rounded XL", Shape: avatar.ShapeRoundedXl})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Squircle", Shape: avatar.ShapeSquircle})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Heart", Shape: avatar.ShapeHeart})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Hexagon", Shape: avatar.ShapeHexagon})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Status",
				TemplCode: `@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "Online", Status: avatar.StatusOnline})
@avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "Offline", Status: avatar.StatusOffline})`,
			}) {
				<div class="flex flex-wrap items-center gap-4">
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Online", Status: avatar.StatusOnline})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "Offline", Status: avatar.StatusOffline})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Placeholder",
				TemplCode: `@avatar.Avatar(avatar.Props{Placeholder: true, Size: avatar.SizeLg}) {
    <span class="text-3xl">D</span>
}
@avatar.Avatar(avatar.Props{Placeholder: true, Size: avatar.SizeMd}) {
    <span class="text-xl">JD</span>
}`,
			}) {
				<p class="text-sm mb-3">Text content is shown when no image source is provided.</p>
				<div class="flex flex-wrap items-center gap-4">
					@avatar.Avatar(avatar.Props{Placeholder: true, Size: avatar.SizeLg}) {
						<span class="text-3xl">D</span>
					}
					@avatar.Avatar(avatar.Props{Placeholder: true, Size: avatar.SizeMd}) {
						<span class="text-xl">JD</span>
					}
					@avatar.Avatar(avatar.Props{Placeholder: true, Size: avatar.SizeSm}) {
						<span>AB</span>
					}
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Avatar Group",
				TemplCode: `@avatar.Group() {
    @avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "User 1"})
    @avatar.Avatar(avatar.Props{Src: "photo.webp", Alt: "User 2"})
    @avatar.Avatar(avatar.Props{Placeholder: true}) {
        <span>+99</span>
    }
}`,
			}) {
				@avatar.Group() {
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "User 1"})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "User 2"})
					@avatar.Avatar(avatar.Props{Src: sampleAvatarImg, Alt: "User 3"})
					@avatar.Avatar(avatar.Props{Placeholder: true}) {
						<span>+99</span>
					}
				}
			}
		</div>
	}
}
