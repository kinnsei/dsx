package pages

import (
	"github.com/kinnsei/dsx/cmd/showcase/internal/layouts"
	"github.com/kinnsei/dsx/ui/markdown"
)

templ GettingStarted(content string) {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "Getting Started — WebX Showcase",
		Description: "Getting started guide for the WebX framework",
		CurrentPath: "/getting-started",
	}) {
		@markdown.Markdown(markdown.Props{
			Content: content,
		})
	}
}
