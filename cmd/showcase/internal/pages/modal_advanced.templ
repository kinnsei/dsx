package pages

import (
	"github.com/plaenen/webx"
	"github.com/plaenen/webx/cmd/showcase/internal/components"
	"github.com/plaenen/webx/cmd/showcase/internal/layouts"
	"github.com/plaenen/webx/ds"
)

templ ModalAdvanced() {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "SSE SDK — WebX Showcase",
		Description: "Backend SDK helpers: Modal, Confirm, Redirect, Patch, Download",
		CurrentPath: "/components/sse-sdk",
	}) {
		{{
			wxctx := webx.FromContext(ctx)
		}}
		<div class="space-y-8">
			<div>
				<h1 class="text-3xl font-bold">SSE SDK</h1>
				<p class="text-base-content/70 mt-2">
					Backend helpers that send SSE events to the browser via
					<code class="bg-base-200 px-1.5 py-0.5 rounded text-xs">ds.Send.XXX</code>.
					All interactions are server-driven — no client-side JavaScript.
				</p>
			</div>
			<!-- Modal -->
			@components.Example(components.ExampleProps{
				Title: "Modal",
				TemplCode: `<button
    class="btn btn-primary btn-sm"
    { ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/show")))... }
>
    Open Modal
</button>`,
				HandlerCode: `func (h *modalHandlers) showModal() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        sse := datastar.NewSSE(w, r)
        ds.Send.Modal(sse, pages.ModalContent())
    }
}`,
			}) {
				<p class="text-sm text-base-content/70 mb-4">
					Opens a centered dialog with server-rendered content. Closes via overlay click, close button, or server-side HideModal.
				</p>
				<div class="flex flex-wrap gap-3">
					<button
						class="btn btn-primary btn-sm"
						{ ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/show")))... }
					>
						Open Modal
					</button>
					<button
						class="btn btn-sm"
						{ ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/show-wide")))... }
					>
						Wide Modal
					</button>
				</div>
			}
			<!-- Confirm -->
			@components.Example(components.ExampleProps{
				Title: "Confirm",
				TemplCode: `<button
    class="btn btn-primary btn-sm"
    { ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/confirm")))... }
>
    Ask Confirmation
</button>`,
				HandlerCode: `func (h *modalHandlers) showConfirm() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        wxctx := webx.FromContext(r.Context())
        sse := datastar.NewSSE(w, r)
        ds.Send.Confirm(sse, "Are you sure?",
            wxctx.APIPath("/modal/confirmed"),
        )
    }
}

// Danger variant with custom styling:
ds.Send.Confirm(sse, "Delete all data?",
    wxctx.APIPath("/data/purge"),
    ds.WithConfirmTitle("Danger Zone"),
    ds.WithConfirmLabel("Delete Everything"),
    ds.WithConfirmClass("btn btn-error"),
)`,
			}) {
				<p class="text-sm text-base-content/70 mb-4">
					A confirmation dialog with confirm/cancel buttons. Confirm triggers a server action, cancel closes the dialog.
				</p>
				<div class="flex flex-wrap gap-3">
					<button
						class="btn btn-primary btn-sm"
						{ ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/confirm")))... }
					>
						Ask Confirmation
					</button>
					<button
						class="btn btn-error btn-sm"
						{ ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/confirm-danger")))... }
					>
						Danger Confirm
					</button>
				</div>
			}
			<!-- Patch -->
			@components.Example(components.ExampleProps{
				Title: "Patch",
				TemplCode: `<div id="patch-target" class="p-3 bg-base-200 rounded-box text-sm">
    Click the button to patch this element.
</div>
<button
    class="btn btn-primary btn-sm"
    { ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/patch")))... }
>
    Patch Content
</button>`,
				HandlerCode: `func (h *modalHandlers) patchContent() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        sse := datastar.NewSSE(w, r)
        timestamp := time.Now().Format("15:04:05")
        ds.Send.Patch(sse, pages.PatchedContent(timestamp))
    }
}`,
			}) {
				<p class="text-sm text-base-content/70 mb-4">
					Renders a templ component server-side and patches it into the DOM by ID.
				</p>
				<div id="patch-target" class="p-3 bg-base-200 rounded-box text-sm">
					Click the button to patch this element with server-rendered content.
				</div>
				<div class="mt-4">
					<button
						class="btn btn-primary btn-sm"
						{ ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/patch")))... }
					>
						Patch Content
					</button>
				</div>
			}
			<!-- Redirect -->
			@components.Example(components.ExampleProps{
				Title: "Redirect",
				TemplCode: `<button
    class="btn btn-primary btn-sm"
    { ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/redirect")))... }
>
    Redirect to Home
</button>`,
				HandlerCode: `func (h *modalHandlers) redirect() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        wxctx := webx.FromContext(r.Context())
        sse := datastar.NewSSE(w, r)
        ds.Send.Redirect(sse, wxctx.BasePath+"/")
    }
}`,
			}) {
				<p class="text-sm text-base-content/70 mb-4">
					Navigates the browser to a new URL via SSE. Useful after form submissions or actions.
				</p>
				<button
					class="btn btn-primary btn-sm"
					{ ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/redirect")))... }
				>
					Redirect to Home
				</button>
			}
			<!-- Download -->
			@components.Example(components.ExampleProps{
				Title: "Download",
				TemplCode: `<button
    class="btn btn-primary btn-sm"
    { ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/download")))... }
>
    Download File
</button>`,
				HandlerCode: `func (h *modalHandlers) download() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        wxctx := webx.FromContext(r.Context())
        sse := datastar.NewSSE(w, r)
        ds.Send.Download(sse,
            wxctx.APIPath("/reports/export.csv"),
            "export.csv",
        )
    }
}`,
			}) {
				<p class="text-sm text-base-content/70 mb-4">
					Triggers a file download without navigating away from the page.
				</p>
				<button
					class="btn btn-primary btn-sm"
					{ ds.OnClick(ds.GetOnce(wxctx.APIPath("/modal/download")))... }
				>
					Download File
				</button>
			}
		</div>
	}
}

templ ModalContent() {
	<h2 class="text-2xl font-bold">Modal Title</h2>
	<p class="text-base-content/70 mt-2">
		This content was rendered server-side and delivered via SSE.
		The modal shell (overlay, dialog, close button) is added automatically by
		<code class="bg-base-200 px-1.5 py-0.5 rounded text-xs">ds.Send.Modal</code>.
	</p>
	<div class="mt-4 space-y-2 text-sm">
		<p>You can put any templ component here — forms, tables, detail views, etc.</p>
		<p>Click the ✕ button or the overlay to close.</p>
	</div>
}

templ ModalContentWide() {
	<h2 class="text-2xl font-bold">Wide Modal</h2>
	<p class="text-base-content/70 mt-2">
		This modal uses <code class="bg-base-200 px-1.5 py-0.5 rounded text-xs">{ `ds.WithModalMaxWidth("max-w-2xl")` }</code> { "for" } a wider dialog.
	</p>
	<div class="grid grid-cols-2 gap-4 mt-4">
		<div class="bg-base-200 rounded-box p-4">
			<h3 class="font-semibold">Left Column</h3>
			<p class="text-sm text-base-content/70 mt-1">Server-rendered content in a two-column layout.</p>
		</div>
		<div class="bg-base-200 rounded-box p-4">
			<h3 class="font-semibold">Right Column</h3>
			<p class="text-sm text-base-content/70 mt-1">Works naturally with any Tailwind grid or flex layout.</p>
		</div>
	</div>
}

templ PatchedContent(timestamp string) {
	<div id="patch-target" class="mt-4 p-3 bg-success/10 rounded-box text-sm text-success">
		This content was patched from the server at { timestamp }.
	</div>
}
