package pages

import (
	"github.com/plaenen/webx/cmd/showcase/internal/components"
	"github.com/plaenen/webx/cmd/showcase/internal/layouts"
	"github.com/plaenen/webx/ui/aichat"
	"github.com/plaenen/webx/ui/commandbar"
)

templ AIChats() {
	@layouts.Showcase(layouts.ShowcaseProps{
		Title:       "AI Chat — WebX Showcase",
		Description: "Conversational AI chat widget",
		CurrentPath: "/components/ai-chat",
	}) {
		<div class="space-y-8">
			<div>
				<h1 class="text-3xl font-bold">AI Chat</h1>
				<p class="text-base-content/70 mt-2">
					A conversational AI chat widget with collapsed/expanded states, multi-turn messaging,
					quick replies, rich response cards, and member assignment. Messages are delivered via SSE.
				</p>
			</div>
			<p class="text-sm text-base-content/60">
				Click the bar to open, then try: "cancel a subscription", "plan a date night", "max needs football boots size 38", or any other message.
			</p>
			@components.Example(components.ExampleProps{
				Title: "Live Demo",
				TemplCode: `@aichat.AIChat(aichat.Props{
    ID:        "demo-aichat",
    SubmitURL: "/showcase/aichat/send",
})`,
				HandlerCode: `func (h *handler) send() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        var signals aichat.AIChatSignals
        if err := aichat.ReadSignals("demo-aichat", r, &signals); err != nil {
            http.Error(w, err.Error(), http.StatusBadRequest)
            return
        }

        input := strings.TrimSpace(signals.Input)
        if input == "" {
            return
        }

        // Use the ChatSender helper for all SSE operations
        sse := datastar.NewSSE(w, r)
        chat := aichat.Chat(sse, "demo-aichat")

        _ = chat.UserMessage(input)
        _ = chat.ShowTyping()
        time.Sleep(800 * time.Millisecond)
        _ = chat.HideTyping()

        // Simple text reply
        _ = chat.AssistantText("Here's what I found.")

        // Or append any component (cards, quick replies, etc.)
        _ = chat.Append(aichat.QuickReplies(aichat.QuickRepliesProps{
            ChatID:    "demo-aichat",
            SubmitURL: "/chat/send",
            Options:   []aichat.QuickReply{{Label: "Yes", Value: "yes"}},
        }))
    }
}`,
			}) {
				<div class="max-w-lg mx-auto">
					@aichat.AIChat(aichat.Props{
						ID:        "demo-aichat",
						SubmitURL: "/showcase/aichat/send",
					})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Custom Placeholder",
				TemplCode: `@aichat.AIChat(aichat.Props{
    Placeholder:      "Ask the AI assistant...",
    ReplyPlaceholder: "Follow up...",
    Shortcut:         "⌘J",
    SubmitURL:        "/showcase/aichat/send",
})`,
			}) {
				<div class="max-w-lg mx-auto">
					@aichat.AIChat(aichat.Props{
						ID:               "demo-custom",
						Placeholder:      "Ask the AI assistant...",
						ReplyPlaceholder: "Follow up...",
						Shortcut:         "⌘J",
						SubmitURL:        "/showcase/aichat/send",
					})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "User Message",
				TemplCode: `@aichat.UserMessage(aichat.UserMessageProps{
    Text: "max needs football boots size 38",
})`,
			}) {
				<div class="max-w-lg mx-auto space-y-3 p-4 rounded-box border border-base-300">
					@aichat.UserMessage(aichat.UserMessageProps{
						Text: "max needs football boots size 38",
					})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Assistant Message",
				TemplCode: `@aichat.AssistantMessage() {
    @aichat.AssistantText("Love it. When are you thinking?")
}`,
			}) {
				<div class="max-w-lg mx-auto space-y-3 p-4 rounded-box border border-base-300">
					@aichat.AssistantMessage() {
						@aichat.AssistantText("Love it. When are you thinking?")
					}
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Typing Indicator",
				TemplCode: `@aichat.Typing(aichat.TypingProps{})`,
			}) {
				<div class="max-w-lg mx-auto space-y-3 p-4 rounded-box border border-base-300">
					@aichat.Typing(aichat.TypingProps{})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Quick Replies",
				TemplCode: `@aichat.AssistantMessage() {
    @aichat.AssistantText("You have 8 active subscriptions. Which one?")
}
@aichat.QuickReplies(aichat.QuickRepliesProps{
    ChatID:    "demo-aichat",
    SubmitURL: "/showcase/aichat/send",
    Options: []aichat.QuickReply{
        {Label: "Netflix €12.99", Value: "Netflix"},
        {Label: "Spotify €17.99", Value: "Spotify"},
        {Label: "YouTube €11.99", Value: "YouTube"},
        {Label: "Show all 8", Value: "Show all"},
    },
})`,
			}) {
				<div class="max-w-lg mx-auto space-y-3 p-4 rounded-box border border-base-300">
					@aichat.AssistantMessage() {
						@aichat.AssistantText("You have 8 active subscriptions. Which one?")
					}
					@aichat.QuickReplies(aichat.QuickRepliesProps{
						ChatID:    "demo-aichat",
						SubmitURL: "/showcase/aichat/send",
						Options: []aichat.QuickReply{
							{Label: "Netflix €12.99", Value: "Netflix"},
							{Label: "Spotify €17.99", Value: "Spotify"},
							{Label: "YouTube €11.99", Value: "YouTube"},
							{Label: "Show all 8", Value: "Show all"},
						},
					})
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "Response Card",
				TemplCode: `@aichat.AssistantMessage() {
    @aichat.ResponseCard(aichat.ResponseCardProps{
        Title:       "Buy football boots for Max (size 38)",
        Description: "Last purchase Aug '24 (size 37). Decathlon has options €35–85.",
        Tags: []aichat.CardTag{
            {Label: "Shopping"},
            {Label: "Needs input", Variant: "warning"},
            {Label: "Standalone"},
        },
    }) {
        @aichat.AssignRow(...)
        @aichat.ActionBar(...)
    }
}`,
			}) {
				<div class="max-w-lg mx-auto space-y-3 p-4 rounded-box border border-base-300">
					@aichat.AssistantMessage() {
						@aichat.ResponseCard(aichat.ResponseCardProps{
							Title:       "Buy football boots for Max (size 38)",
							Description: "Last purchase Aug '24 (size 37). Decathlon has options €35–85. Want me to find the best deals?",
							Tags: []aichat.CardTag{
								{Label: "Shopping"},
								{Label: "Needs input", Variant: "warning"},
								{Label: "Standalone"},
							},
						}) {
							@aichat.AssignRow(aichat.AssignRowProps{
								Members: []aichat.Member{
									{Initials: "ME", Name: "You", Color: "bg-success", Active: true},
									{Initials: "SA", Name: "Sarah", Color: "bg-secondary"},
									{Initials: "MX", Name: "Max", Color: "bg-warning"},
									{Initials: "LI", Name: "Lily", Color: "bg-error"},
								},
							})
							@aichat.ActionBar(aichat.ActionBarProps{
								PrimaryLabel: "Add to inbox ✦",
								PrimaryURL:   "/showcase/aichat/action",
								DiscardURL:   "/showcase/aichat/action",
							})
						}
					}
				</div>
			}
			@components.Example(components.ExampleProps{
				Title: "With Command Bar",
				TemplCode: `@aichat.AIChat(aichat.Props{
    ID: "demo-combined",
    InputSlot: commandbar.CommandBar(commandbar.Props{
        ID:          "combined-bar",
        Embedded:    true,
        Placeholder: "Type, upload, or record...",
        SubmitURL:   "/showcase/aichat/send-combined",
        UploadURL:   "/showcase/aichat/upload",
        VoiceURL:    "/showcase/aichat/voice",
        Suggestions: []string{"Cancel a subscription", "Plan date night"},
    }),
})`,
				HandlerCode: `// When using an embedded CommandBar, input comes from the
// command bar's "text" signal instead of the AI chat's "input" signal.
func (h *handler) sendCombined() http.HandlerFunc {
    return func(w http.ResponseWriter, r *http.Request) {
        // Read from the command bar's signal namespace
        var signals commandbar.CommandBarSignals
        if err := ds.ReadSignals("combined-bar", r, &signals); err != nil {
            http.Error(w, err.Error(), http.StatusBadRequest)
            return
        }

        input := strings.TrimSpace(signals.Text)
        if input == "" {
            return
        }

        // Use the ChatSender helper — same API regardless of input source
        sse := datastar.NewSSE(w, r)
        chat := aichat.Chat(sse, "demo-combined")

        _ = chat.UserMessage(input)
        _ = chat.ShowTyping()
        time.Sleep(800 * time.Millisecond)
        _ = chat.HideTyping()
        _ = chat.AssistantText("Got it!")
    }
}`,
			}) {
				<div class="max-w-lg mx-auto">
					@aichat.AIChat(aichat.Props{
						ID: "demo-combined",
						InputSlot: commandbar.CommandBar(commandbar.Props{
							ID:          "combined-bar",
							Embedded:    true,
							Placeholder: "Type, upload, or record...",
							SubmitURL:   "/showcase/aichat/send-combined",
							UploadURL:   "/showcase/aichat/upload",
							VoiceURL:    "/showcase/aichat/voice",
							Suggestions: []string{"Cancel a subscription", "Plan date night"},
						}),
					})
				</div>
			}
		</div>
	}
}
