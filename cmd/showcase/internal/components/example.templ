package components

import (
	"github.com/kinnsei/dsx/ui/badge"
	"github.com/kinnsei/dsx/ui/codeview"
	"github.com/kinnsei/dsx/ui/tab"
	"github.com/kinnsei/dsx/utils"
)

type ExampleProps struct {
	Title       string
	TemplCode   string // templ source code (shown in "Templ" tab)
	HandlerCode string // Go handler source code (shown in "Handler" tab, optional)
}

// Example renders a tabbed card with Preview | Templ | Handler tabs.
// Preview shows the live demo (children). Templ and Handler show syntax-highlighted code.
// If HandlerCode is empty, the Handler tab is omitted.
templ Example(props ExampleProps) {
	{{ tabName := "example-" + utils.RandomID() }}
	<div class="space-y-2">
		if props.Title != "" {
			<div class="flex items-center gap-2">
				<h2 class="text-xl font-semibold">{ props.Title }</h2>
				if props.HandlerCode != "" {
					@badge.Badge(badge.Props{Variant: badge.VariantWarning, Size: badge.SizeSm}) {
						Requires handler
					}
				}
			</div>
		}
		@tab.Tabs(tab.Props{Variant: tab.VariantBorder}) {
			@tab.RadioTab(tab.RadioTabProps{Name: tabName, Label: "Preview", Checked: true})
			@tab.Content(tab.ContentProps{Class: "border border-base-300 bg-base-100 p-6"}) {
				{ children... }
			}
			@tab.RadioTab(tab.RadioTabProps{Name: tabName, Label: "Templ"})
			@tab.Content(tab.ContentProps{Class: "border border-base-300 bg-base-100 p-4"}) {
				@codeview.CodeView(codeview.Props{Code: props.TemplCode, Language: "templ"})
			}
			if props.HandlerCode != "" {
				@tab.RadioTab(tab.RadioTabProps{Name: tabName, Label: "Handler"})
				@tab.Content(tab.ContentProps{Class: "border border-base-300 bg-base-100 p-4"}) {
					@codeview.CodeView(codeview.Props{Code: props.HandlerCode, Language: "go"})
				}
			}
		}
	</div>
}
